HOST=0.0.0.0
PORT=1337

# App Keys (generate these)
APP_KEYS=key1,key2,key3,key4

# Admin
ADMIN_JWT_SECRET=your-admin-jwt-secret
API_TOKEN_SALT=your-api-token-salt
# i18n export scripts (scripts/i18n/export-content.js)
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your-read-api-token

# Transfer a producción (scripts/transfer-prod.js) — Strapi Cloud
# URL base de tu Strapi Cloud (el script le agrega /admin)
STRAPI_TRANSFER_URL=https://your-project.strapiapp.com
# Transfer token de PROD: Admin de Cloud → Settings → Transfer Tokens (NO es el API token)
STRAPI_TRANSFER_TOKEN=your-prod-transfer-token

# Instant FE cache bust on publish/update (must match Vercel REVALIDATE_SECRET)
# FRONTEND_REVALIDATE_URL=https://frequenzamusic.com/api/revalidate
# REVALIDATE_SECRET=your-random-secret
