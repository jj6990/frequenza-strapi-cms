{
	"kind": "collectionType",
	"collectionName": "events",
	"info": {
		"singularName": "event",
		"pluralName": "events",
		"displayName": "Event"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {
		"i18n": {
			"localized": true
		}
	},
	"attributes": {
		"title": {
			"type": "string",
			"pluginOptions": {
				"i18n": {
					"localized": true
				}
			}
		},
		"eventDescription": {
			"type": "customField",
			"customField": "plugin::ckeditor5.CKEditor",
			"options": {
				"preset": "defaultHtml"
			},
			"pluginOptions": {
				"i18n": {
					"localized": true
				}
			}
		},
		"description": {
			"type": "blocks",
			"pluginOptions": {
				"i18n": {
					"localized": true
				}
			}
		},
		"location": {
			"type": "string",
			"pluginOptions": {
				"i18n": {
					"localized": true
				}
			}
		},
		"startTime": {
			"type": "time",
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		},
		"price": {
			"type": "decimal",
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		},
		"slug": {
			"type": "uid",
			"targetField": "title",
			"pluginOptions": {
				"i18n": {
					"localized": true
				}
			}
		},
		"isActive": {
			"type": "boolean",
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		},
		"eventImage": {
			"type": "media",
			"multiple": false,
			"allowedTypes": ["images", "files", "videos", "audios"],
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		},
		"eventsPhotos": {
			"type": "media",
			"multiple": true,
			"allowedTypes": ["images", "files", "videos", "audios"],
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		},
		"date": {
			"type": "date",
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		},
		"priceTiers": {
			"type": "component",
			"repeatable": true,
			"component": "event.price-tier",
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		},
		"enablePriceTiers": {
			"type": "boolean",
			"default": false,
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		},
		"media_player": {
			"type": "relation",
			"relation": "oneToOne",
			"target": "api::media-player.media-player",
			"pluginOptions": {
				"i18n": {
					"localized": false
				}
			}
		}
	}
}
