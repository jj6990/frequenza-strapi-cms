{
	"kind": "collectionType",
	"collectionName": "events",
	"info": {
		"singularName": "event",
		"pluralName": "events",
		"displayName": "Event"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"title": {
			"type": "string"
		},
		"eventDescription": {
			"type": "customField",
			"customField": "plugin::ckeditor5.CKEditor",
			"options": {
				"preset": "defaultHtml"
			}
		},
		"description": {
			"type": "blocks"
		},
		"location": {
			"type": "string"
		},
		"startTime": {
			"type": "time"
		},
		"price": {
			"type": "decimal"
		},
		"slug": {
			"type": "uid",
			"targetField": "title"
		},
		"isActive": {
			"type": "boolean"
		},
		"eventImage": {
			"type": "media",
			"multiple": false,
			"allowedTypes": ["images", "files", "videos", "audios"]
		},
		"eventsPhotos": {
			"type": "media",
			"multiple": true,
			"allowedTypes": ["images", "files", "videos", "audios"]
		},
		"date": {
			"type": "date"
		},
		"priceTiers": {
			"type": "component",
			"repeatable": true,
			"component": "event.price-tier"
		},
		"enablePriceTiers": {
			"type": "boolean",
			"default": false
		}
	}
}
