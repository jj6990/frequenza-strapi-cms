{
  "kind": "collectionType",
  "collectionName": "media_items",
  "info": {
    "singularName": "media-item",
    "pluralName": "media-items",
    "displayName": "Media Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "url": {
      "type": "string",
      "required": true
    },
    "key": {
      "type": "string",
      "unique": true,
      "configurable": false
    },
    "title": {
      "type": "string",
      "configurable": false
    },
    "type": {
      "type": "enumeration",
      "enum": ["soundcloud", "youtube"],
      "configurable": false
    },
    "media_player": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::media-player.media-player",
      "inversedBy": "media_items"
    }
  }
}
