{
  "name": "my-app-name",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "strapi build",
    "deploy": "strapi deploy",
    "dev": "strapi develop",
    "seed:example": "node ./scripts/seed.js",
    "i18n:export": "node ./scripts/i18n/export-content.js",
    "i18n:validate": "node ./scripts/i18n/build-en-seed.js --check",
    "i18n:scaffold-en": "node ./scripts/i18n/build-en-seed.js --scaffold",
    "i18n:seed": "node ./scripts/i18n/seed-localizations.js",
    "i18n:pipeline": "node ./scripts/i18n/export-content.js && node ./scripts/i18n/build-en-seed.js && node ./scripts/i18n/seed-localizations.js",
    "start": "strapi start",
    "strapi": "strapi"
  },
  "dependencies": {
    "@_sh/strapi-plugin-ckeditor": "^7.1.1",
    "@strapi/plugin-cloud": "5.50.0",
    "@strapi/plugin-users-permissions": "5.50.0",
    "@strapi/strapi": "5.50.0",
    "better-sqlite3": "11.3.0",
    "csv-parser": "^3.2.0",
    "fs-extra": "^10.0.0",
    "mime-types": "^2.1.27",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0 <=22.x.x",
    "npm": ">=6.0.0"
  }
}
